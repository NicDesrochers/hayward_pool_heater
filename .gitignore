# Gitignore settings for ESPHome
# This is an example and may include too much for your use-case.
# You can modify this file to suit your needs.
/.esphome/
**/.esphome/
/.esphome-config/
/.cache/
__pycache__/
*.py[cod]
/.venv/
/secrets.yaml
/esphome_build/
/build/
/dist/
/backup
/tmp/
.env
analysis/startlog.sh
analysis/.vscode/launch.json
.vscode/launch.json
.vscode/tasks.json
analysis/piscine_esphome_logs.log
analysis/captures/
analysis/annotations/
analysis/screenshots/*
!analysis/screenshots/
!analysis/screenshots/hwp-web-tablet.png
analysis/hwp-web-annotations*.json
components/hwp/.vscode/launch.json
components/hwp/.vscode/tasks.json
hayward-heater-test.yaml
*-local.yaml
*-secrets.yaml
